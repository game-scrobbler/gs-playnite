<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ── Section 1: Installation ID ── -->
    <sys:String x:Key="LOCGsPluginInstallIdSectionTitle">安装 ID</sys:String>
    <sys:String x:Key="LOCGsPluginInstallIdDescription">插件的唯一安装标识符，用于关联您的账户。</sys:String>
    <sys:String x:Key="LOCGsPluginInstallIdCopyHint">点击上方 ID 可复制到剪贴板。</sys:String>
    <sys:String x:Key="LOCGsPluginInstallIdCopyTooltip">点击复制 ID</sys:String>

    <!-- ── Section 2: Theme &amp; Features ── -->
    <sys:String x:Key="LOCGsPluginThemeSectionTitle">主题与功能</sys:String>
    <sys:String x:Key="LOCGsPluginThemeDescription">控制 Game Scrobbler 侧边栏和视图的视觉主题。</sys:String>
    <sys:String x:Key="LOCGsPluginNewDashboardExperienceLabel">测试通道 — 抢先体验新功能</sys:String>
    <sys:String x:Key="LOCGsPluginNewDashboardExperienceTooltip">加入后可在正式发布前测试新功能。功能可能尚未完善或会发生变化。</sys:String>

    <!-- ── Section 3: Account Linking ── -->
    <sys:String x:Key="LOCGsPluginAccountLinkingSectionTitle">账户关联</sys:String>
    <sys:String x:Key="LOCGsPluginLinkOnWebsiteButton">在网站上关联账户</sys:String>
    <sys:String x:Key="LOCGsPluginManualTokenSeparator">或手动输入令牌</sys:String>
    <sys:String x:Key="LOCGsPluginLinkAccountButton">关联账户</sys:String>
    <sys:String x:Key="LOCGsPluginDisconnectAccountButton">解除关联</sys:String>
    <sys:String x:Key="LOCGsPluginDisconnectAccountTooltip">解除您与 GameScrobbler 的账户关联。您的游戏数据将保留在服务器上。</sys:String>
    <sys:String x:Key="LOCGsPluginDisconnectDialogTitle">解除关联</sys:String>
    <sys:String x:Key="LOCGsPluginDisconnectDialogBody">确定解除账户关联吗？您的游戏数据将保留在服务器上。
您随时可以重新关联。</sys:String>
    <sys:String x:Key="LOCGsPluginDisconnectNoAccount">当前没有关联的账户。</sys:String>
    <sys:String x:Key="LOCGsPluginStatusDisconnected">账户已解除关联。</sys:String>
    <sys:String x:Key="LOCGsPluginStatusTokenExpired">令牌已过期——点击"在网站上关联账户"获取新令牌。</sys:String>
    <sys:String x:Key="LOCGsPluginTokenCountdownFormat">令牌将在 ~{0}:{1} 后过期</sys:String>
    <sys:String x:Key="LOCGsPluginTokenExpiredDialogTitle">令牌已过期</sys:String>
    <sys:String x:Key="LOCGsPluginTokenExpiredDialogBody">您的关联令牌已过期。

是否打开关联页面获取新令牌？</sys:String>
    <sys:String x:Key="LOCGsPluginConfirmLinkingTitle">确认账户关联</sys:String>
    <sys:String x:Key="LOCGsPluginConfirmLinkingBody">一个网站正在请求将此 Playnite 安装关联到一个 GameScrobbler 账户。

仅当您刚刚自己在 gamescrobbler.com 上点击了"关联 Playnite"时才继续。</sys:String>
    <sys:String x:Key="LOCGsPluginLinkSuccessDialogTitle">关联成功</sys:String>
    <sys:String x:Key="LOCGsPluginLinkSuccessDialogBody">账户关联成功！
用户 ID：{0}</sys:String>
    <sys:String x:Key="LOCGsPluginLinkFailedDialogTitle">关联失败</sys:String>
    <sys:String x:Key="LOCGsPluginLinkFailedRetryDialogTitle">关联失败——重试？</sys:String>
    <sys:String x:Key="LOCGsPluginLinkFailedRetriesBody">多次尝试后关联失败：
{0}

请稍后重试。</sys:String>
    <sys:String x:Key="LOCGsPluginLinkFailedNetworkBody">由于网络错误导致关联失败：
{0}

是否重试？</sys:String>
    <sys:String x:Key="LOCGsPluginLinkFailedBody">关联失败：{0}</sys:String>

