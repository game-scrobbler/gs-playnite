    <sys:String x:Key="LOCGsPluginNeverSynced">从未同步</sys:String>
    <sys:String x:Key="LOCGsPluginLastSyncedFormat">上次同步：{0} 款游戏 · {1}</sys:String>

    <!-- ── Elapsed Time ── -->
    <sys:String x:Key="LOCGsPluginElapsedJustNow">刚刚</sys:String>
    <sys:String x:Key="LOCGsPluginElapsedMinutesFormat">{0} 分钟前</sys:String>
    <sys:String x:Key="LOCGsPluginElapsedHoursFormat">{0} 小时前</sys:String>
    <sys:String x:Key="LOCGsPluginElapsedDaysFormat">{0} 天前</sys:String>
    <sys:String x:Key="LOCGsPluginRemainingLessThanMinute">不到一分钟</sys:String>
    <sys:String x:Key="LOCGsPluginRemainingMinutesFormat">{0} 分钟</sys:String>
    <sys:String x:Key="LOCGsPluginRemainingHoursMinutesFormat">{0} 小时 {1} 分钟</sys:String>
    <sys:String x:Key="LOCGsPluginRemainingHoursFormat">{0} 小时</sys:String>

    <!-- ── Achievement Provider ── -->
    <sys:String x:Key="LOCGsPluginAchievementProviderDetectedFormat">已检测到 {0}</sys:String>

    <!-- ── Notification Tooltips ── -->
    <sys:String x:Key="LOCGsPluginShowUpdateNotificationsTooltip">有新插件版本时在 Playnite 中显示通知</sys:String>
    <sys:String x:Key="LOCGsPluginShowImportantNotificationsTooltip">显示有关重要更新和公告的通知</sys:String>

    <!-- ── Privacy Tooltips ── -->
    <sys:String x:Key="LOCGsPluginDisableSentryTooltip">阻止发送崩溃报告和诊断数据</sys:String>
    <sys:String x:Key="LOCGsPluginDisablePostHogTooltip">阻止发送匿名使用分析</sys:String>
    <sys:String x:Key="LOCGsPluginDisableScrobblingTooltip">阻止追踪您的游戏活动</sys:String>
    <sys:String x:Key="LOCGsPluginOptBackInTooltip">重新启用插件并恢复同步</sys:String>

    <!-- ── Clipboard ── -->
    <sys:String x:Key="LOCGsPluginCopiedToClipboard">已复制到剪贴板！</sys:String>
    <sys:String x:Key="LOCGsPluginCopiedDialogTitle">成功</sys:String>
    <sys:String x:Key="LOCGsPluginCopyFailedFormat">复制失败：{0}</sys:String>
    <sys:String x:Key="LOCGsPluginOpenUrlFailedFormat">无法打开链接：{0}</sys:String>
    <sys:String x:Key="LOCGsPluginErrorDialogTitle">错误</sys:String>

    <!-- ── Delete My Data Dialogs ── -->
    <sys:String x:Key="LOCGsPluginDeleteConfirmBody">确定要从 GameScrobbler 服务器删除所有数据吗？

此操作将：
• 从服务器移除您的游戏库、会话和成就
• 禁用所有插件功能
• 需要重新同意才能继续使用插件

此操作不可撤销。</sys:String>
    <sys:String x:Key="LOCGsPluginDeleteConfirmTitle">删除我的数据</sys:String>
    <sys:String x:Key="LOCGsPluginDeleteFinalBody">您确定吗？数据将从 GameScrobbler 服务器永久删除。</sys:String>
    <sys:String x:Key="LOCGsPluginDeleteFinalTitle">最终确认</sys:String>
    <sys:String x:Key="LOCGsPluginDeletingInProgress">正在删除...</sys:String>

    <!-- ── Opt Back In Dialog ── -->
    <sys:String x:Key="LOCGsPluginOptBackInConfirmBody">重新启用 GameScrobbler 插件？

需要重启 Playnite 才能恢复所有功能。</sys:String>
    <sys:String x:Key="LOCGsPluginOptBackInConfirmTitle">重新启用</sys:String>

    <!-- ── Account Linking: Status Messages ── -->
    <sys:String x:Key="LOCGsPluginPleaseEnterToken">请输入令牌</sys:String>
