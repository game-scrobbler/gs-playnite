<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ── Section 1: Installation ID ── -->
    <sys:String x:Key="LOCGsPluginInstallIdSectionTitle">Installation ID</sys:String>
    <sys:String x:Key="LOCGsPluginInstallIdDescription">Your unique plugin installation identifier, used to link your account.</sys:String>
    <sys:String x:Key="LOCGsPluginInstallIdCopyHint">Click the ID above to copy it to your clipboard.</sys:String>
    <sys:String x:Key="LOCGsPluginInstallIdCopyTooltip">Click to copy ID to clipboard</sys:String>

    <!-- ── Section 2: Theme &amp; Dashboard ── -->
    <sys:String x:Key="LOCGsPluginThemeSectionTitle">Theme &amp; Dashboard</sys:String>
    <sys:String x:Key="LOCGsPluginThemeDescription">Controls the visual theme applied to the Game Scrobbler sidebar and views.</sys:String>
    <sys:String x:Key="LOCGsPluginNewDashboardExperienceLabel">New Dashboard Experience</sys:String>
    <sys:String x:Key="LOCGsPluginNewDashboardExperienceTooltip">Enable the new dashboard experience with enhanced features</sys:String>

    <!-- ── Section 3: Account Linking ── -->
    <sys:String x:Key="LOCGsPluginAccountLinkingSectionTitle">Account Linking</sys:String>
    <sys:String x:Key="LOCGsPluginLinkOnWebsiteButton">Link Account on Website</sys:String>
    <sys:String x:Key="LOCGsPluginManualTokenSeparator">or enter your token manually</sys:String>
    <sys:String x:Key="LOCGsPluginLinkAccountButton">Link Account</sys:String>
    <sys:String x:Key="LOCGsPluginDisconnectAccountButton">Disconnect Account</sys:String>
    <sys:String x:Key="LOCGsPluginDisconnectAccountTooltip">Disconnects your account from GameScrobbler. Your game data is kept on the server.</sys:String>
    <sys:String x:Key="LOCGsPluginDisconnectDialogTitle">Disconnect Account</sys:String>
    <sys:String x:Key="LOCGsPluginDisconnectDialogBody">Disconnect your account? Your game data will be kept on the server.
You can re-link anytime.</sys:String>
    <sys:String x:Key="LOCGsPluginDisconnectNoAccount">No account is currently linked.</sys:String>
    <sys:String x:Key="LOCGsPluginStatusDisconnected">Account disconnected.</sys:String>
    <sys:String x:Key="LOCGsPluginStatusTokenExpired">Token expired — click "Open website to link" to get a new one.</sys:String>
    <sys:String x:Key="LOCGsPluginTokenCountdownFormat">Token expires in ~{0}:{1}</sys:String>
    <sys:String x:Key="LOCGsPluginTokenExpiredDialogTitle">Token Expired</sys:String>
    <sys:String x:Key="LOCGsPluginTokenExpiredDialogBody">Your link token has expired.

Would you like to open the linking page to get a new one?</sys:String>
    <sys:String x:Key="LOCGsPluginConfirmLinkingTitle">Confirm Account Linking</sys:String>
    <sys:String x:Key="LOCGsPluginConfirmLinkingBody">A website is requesting to link this Playnite installation to a GameScrobbler account.

Only continue if you just clicked "Link Playnite" on gamescrobbler.com yourself.</sys:String>
    <sys:String x:Key="LOCGsPluginLinkSuccessDialogTitle">Account Linking Success</sys:String>
    <sys:String x:Key="LOCGsPluginLinkSuccessDialogBody">Account successfully linked!
User ID: {0}</sys:String>
    <sys:String x:Key="LOCGsPluginLinkFailedDialogTitle">Account Linking Failed</sys:String>
    <sys:String x:Key="LOCGsPluginLinkFailedRetryDialogTitle">Account Linking Failed — Retry?</sys:String>
    <sys:String x:Key="LOCGsPluginLinkFailedRetriesBody">Account linking failed after multiple attempts:
{0}

Please try again later.</sys:String>
    <sys:String x:Key="LOCGsPluginLinkFailedNetworkBody">Account linking failed due to a network error:
{0}

Would you like to retry?</sys:String>
    <sys:String x:Key="LOCGsPluginLinkFailedBody">Account linking failed: {0}</sys:String>

    <!-- ── Section 4: Sync Settings ── -->
    <sys:String x:Key="LOCGsPluginSyncSettingsSectionTitle">Sync Settings</sys:String>
    <sys:String x:Key="LOCGsPluginSyncAchievementsLabel">Sync achievement data (requires SuccessStory or Playnite Achievements addon)</sys:String>
    <sys:String x:Key="LOCGsPluginSyncAchievementsTooltip">Reads achievement data from SuccessStory or Playnite Achievements addon during library sync. Has no effect if neither is installed.</sys:String>
    <sys:String x:Key="LOCGsPluginAchievementProviderMissingWarning">No achievement addon found — achievement sync will be skipped.</sys:String>
    <sys:String x:Key="LOCGsPluginAchievementProviderInstallLink">Install an achievement addon</sys:String>
    <sys:String x:Key="LOCGsPluginLibrarySyncLabel">Library Sync:</sys:String>

    <!-- ── Section 5: Notifications ── -->
    <sys:String x:Key="LOCGsPluginNotificationsSectionTitle">Notifications</sys:String>
    <sys:String x:Key="LOCGsPluginShowUpdateNotificationsLabel">Show version update notifications</sys:String>
    <sys:String x:Key="LOCGsPluginShowImportantNotificationsLabel">Show important notifications from GameScrobbler</sys:String>

    <!-- ── Section 6: Privacy Controls ── -->
    <sys:String x:Key="LOCGsPluginPrivacySectionTitle">Privacy Controls</sys:String>
    <sys:String x:Key="LOCGsPluginDisableSentryLabel">Disable error reporting (Sentry)</sys:String>
    <sys:String x:Key="LOCGsPluginDisablePostHogLabel">Disable analytics (PostHog)</sys:String>
    <sys:String x:Key="LOCGsPluginDisableScrobblingLabel">Disable game activity tracking (Scrobbling)</sys:String>
    <sys:String x:Key="LOCGsPluginScrobblingDisabledWarning">You will not be able to benefit from features that rely on session data</sys:String>

    <!-- ── Section 7: Danger Zone ── -->
    <sys:String x:Key="LOCGsPluginDangerZoneSectionTitle">Danger Zone</sys:String>
    <sys:String x:Key="LOCGsPluginDangerZoneWarning">Please only use this option if you want to delete your Playnite data in the GameScrobbler servers. After your delete request you cannot continue using the GameScrobbler addon without opting in again.</sys:String>
    <sys:String x:Key="LOCGsPluginDeleteMyDataButton">Delete My Data</sys:String>
    <sys:String x:Key="LOCGsPluginOptBackInButton">Opt Back In</sys:String>

    <!-- ── Account Linking: Additional UI strings ── -->
    <sys:String x:Key="LOCGsPluginAccountLinkingHintPrefix">Link your plugin to your GS account to own and persist your data. Visit </sys:String>
    <sys:String x:Key="LOCGsPluginAccountLinkingHintSuffix"> to get started.</sys:String>
    <sys:String x:Key="LOCGsPluginStatusLabel">Status:</sys:String>
    <sys:String x:Key="LOCGsPluginConnectionStatusConnected">Connected to GameScrobbler</sys:String>
    <sys:String x:Key="LOCGsPluginConnectionStatusDisconnected">Disconnected</sys:String>
    <sys:String x:Key="LOCGsPluginConnectionStatusOptedOut">Opted Out</sys:String>
    <sys:String x:Key="LOCGsPluginLinkingInProgress">Linking...</sys:String>
    <sys:String x:Key="LOCGsPluginOpenWebsiteToLinkTooltip">Opens gamescrobbler.com in your browser to link your account automatically</sys:String>
    <sys:String x:Key="LOCGsPluginTokenInputTooltip">Enter your account linking token here</sys:String>

    <!-- ── Install Token &amp; Diagnostics ── -->
    <sys:String x:Key="LOCGsPluginTokenStatusActive">&#x2713; Token: Active</sys:String>
    <sys:String x:Key="LOCGsPluginTokenStatusPending">&#x26A0; Token: Pending registration</sys:String>
    <sys:String x:Key="LOCGsPluginPendingScrobblesFormat">{0} scrobbles queued — will retry automatically</sys:String>
    <sys:String x:Key="LOCGsPluginDroppedScrobblesFormat">{0} scrobbles lost due to server errors</sys:String>

    <!-- ── Sync Status ── -->
    <sys:String x:Key="LOCGsPluginNeverSynced">Never synced</sys:String>
    <sys:String x:Key="LOCGsPluginLastSyncedFormat">Last synced: {0} games · {1}</sys:String>

    <!-- ── Elapsed Time ── -->
    <sys:String x:Key="LOCGsPluginElapsedJustNow">just now</sys:String>
    <sys:String x:Key="LOCGsPluginElapsedMinutesFormat">{0} minutes ago</sys:String>
    <sys:String x:Key="LOCGsPluginElapsedHoursFormat">{0} hours ago</sys:String>
    <sys:String x:Key="LOCGsPluginElapsedDaysFormat">{0} days ago</sys:String>
    <sys:String x:Key="LOCGsPluginRemainingLessThanMinute">less than a minute</sys:String>
    <sys:String x:Key="LOCGsPluginRemainingMinutesFormat">{0} minutes</sys:String>
    <sys:String x:Key="LOCGsPluginRemainingHoursMinutesFormat">{0} hours {1} minutes</sys:String>
    <sys:String x:Key="LOCGsPluginRemainingHoursFormat">{0} hours</sys:String>

    <!-- ── Achievement Provider ── -->
    <sys:String x:Key="LOCGsPluginAchievementProviderDetectedFormat">{0} detected</sys:String>

    <!-- ── Notification Tooltips ── -->
    <sys:String x:Key="LOCGsPluginShowUpdateNotificationsTooltip">Show a notification in Playnite when a new plugin version is available</sys:String>
    <sys:String x:Key="LOCGsPluginShowImportantNotificationsTooltip">Show notifications about important updates and announcements</sys:String>

    <!-- ── Privacy Tooltips ── -->
    <sys:String x:Key="LOCGsPluginDisableSentryTooltip">Prevents sending crash reports and diagnostic data to improve the plugin</sys:String>
    <sys:String x:Key="LOCGsPluginDisablePostHogTooltip">Prevents sending anonymous usage analytics to help improve the plugin</sys:String>
    <sys:String x:Key="LOCGsPluginDisableScrobblingTooltip">Prevents scrobbling of your game playing activity</sys:String>
    <sys:String x:Key="LOCGsPluginOptBackInTooltip">Re-enable the plugin and resume syncing</sys:String>

    <!-- ── Clipboard ── -->
    <sys:String x:Key="LOCGsPluginCopiedToClipboard">Text copied to clipboard!</sys:String>
    <sys:String x:Key="LOCGsPluginCopiedDialogTitle">Success</sys:String>
    <sys:String x:Key="LOCGsPluginCopyFailedFormat">Failed to copy text: {0}</sys:String>
    <sys:String x:Key="LOCGsPluginOpenUrlFailedFormat">Failed to open URL: {0}</sys:String>
    <sys:String x:Key="LOCGsPluginErrorDialogTitle">Error</sys:String>

    <!-- ── Delete My Data Dialogs ── -->
    <sys:String x:Key="LOCGsPluginDeleteConfirmBody">Are you sure you want to delete all your data from GameScrobbler servers?

This will:
• Remove your library, sessions, and achievements from our servers
• Disable all plugin features
• Require you to opt in again to resume using the plugin

This action cannot be undone.</sys:String>
    <sys:String x:Key="LOCGsPluginDeleteConfirmTitle">Delete My Data</sys:String>
    <sys:String x:Key="LOCGsPluginDeleteFinalBody">Are you absolutely sure? Your data will be permanently deleted from the GameScrobbler servers.</sys:String>
    <sys:String x:Key="LOCGsPluginDeleteFinalTitle">Final Confirmation</sys:String>
    <sys:String x:Key="LOCGsPluginDeletingInProgress">Deleting...</sys:String>

    <!-- ── Opt Back In Dialog ── -->
    <sys:String x:Key="LOCGsPluginOptBackInConfirmBody">Re-enable the GameScrobbler plugin?

You will need to restart Playnite for all features to resume.</sys:String>
    <sys:String x:Key="LOCGsPluginOptBackInConfirmTitle">Opt Back In</sys:String>

    <!-- ── Account Linking: Status Messages ── -->
    <sys:String x:Key="LOCGsPluginPleaseEnterToken">Please enter a token</sys:String>
    <sys:String x:Key="LOCGsPluginVerifyingToken">Verifying token...</sys:String>
    <sys:String x:Key="LOCGsPluginLinkSuccess">Successfully linked account!</sys:String>
    <sys:String x:Key="LOCGsPluginNetworkErrorRetryFormat">{0} Click "Link Account" to retry.</sys:String>
    <sys:String x:Key="LOCGsPluginErrorRetryFormat">Error: {0} Click "Link Account" to retry.</sys:String>
    <sys:String x:Key="LOCGsPluginErrorFormat">Error: {0}</sys:String>
    <sys:String x:Key="LOCGsPluginUnknownLinkingError">Unknown error occurred during linking</sys:String>
    <sys:String x:Key="LOCGsPluginLinkingErrorFormat">Error during linking: {0}</sys:String>
    <sys:String x:Key="LOCGsPluginNetworkError">Network error — could not reach the server. Please try again.</sys:String>
    <sys:String x:Key="LOCGsPluginUnlinkFailed">Failed to disconnect account.</sys:String>
    <sys:String x:Key="LOCGsPluginAlreadyLinkedBody">Account is already linked to User ID: {0}

Do you want to link to a different account?</sys:String>
    <sys:String x:Key="LOCGsPluginAlreadyLinkedTitle">Account Already Linked</sys:String>

    <!-- ── Data Deletion: Status Messages ── -->
    <sys:String x:Key="LOCGsPluginDeletingRequesting">Requesting data deletion...</sys:String>
    <sys:String x:Key="LOCGsPluginDeleteSuccess">Your data has been deleted. The plugin is now disabled.</sys:String>
    <sys:String x:Key="LOCGsPluginDeleteRateLimited">Too many deletion requests. Please wait 15 minutes and try again.</sys:String>
    <sys:String x:Key="LOCGsPluginDeleteFailed">Failed to request data deletion. Please try again later.</sys:String>
    <sys:String x:Key="LOCGsPluginDeleteError">An error occurred. Please try again later.</sys:String>
    <sys:String x:Key="LOCGsPluginOptBackInSuccess">Plugin re-enabled. Please restart Playnite to resume syncing.</sys:String>

    <!-- ── URI Handler ── -->
    <sys:String x:Key="LOCGsPluginInvalidLinkingToken">Invalid linking token received.</sys:String>
    <sys:String x:Key="LOCGsPluginUnexpectedUriErrorFormat">Unexpected error processing URI request: {0}</sys:String>

    <!-- ── Library Sync Messages ── -->
    <sys:String x:Key="LOCGsPluginSyncCompleted">Library sync completed.</sys:String>
    <sys:String x:Key="LOCGsPluginSyncUpToDate">Library is already up to date.</sys:String>
    <sys:String x:Key="LOCGsPluginSyncCooldownFormat">Library was already synced recently. Try again in {0}.</sys:String>
    <sys:String x:Key="LOCGsPluginSyncCooldownGeneric">Library was already synced recently. Please try again later.</sys:String>
    <sys:String x:Key="LOCGsPluginSyncFailed">Library sync failed. Check logs for details.</sys:String>
    <sys:String x:Key="LOCGsPluginSyncError">Library sync encountered an error.</sys:String>

    <!-- ── Menu Items ── -->
    <sys:String x:Key="LOCGsPluginMenuSyncLibrary">Sync Library Now</sys:String>
    <sys:String x:Key="LOCGsPluginMenuOpenSettings">Open Settings</sys:String>

</ResourceDictionary>
