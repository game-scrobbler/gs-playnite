    <sys:String x:Key="LOCGsPluginAccountLinkingHintPrefix">将插件关联到您的 GS 账户以保存数据。请访问 </sys:String>
    <sys:String x:Key="LOCGsPluginAccountLinkingHintSuffix"> 开始操作。</sys:String>
    <sys:String x:Key="LOCGsPluginStatusLabel">状态：</sys:String>
    <sys:String x:Key="LOCGsPluginConnectionStatusConnected">已连接到 GameScrobbler</sys:String>
    <sys:String x:Key="LOCGsPluginConnectionStatusDisconnected">已断开</sys:String>
    <sys:String x:Key="LOCGsPluginConnectionStatusOptedOut">已退出</sys:String>
    <sys:String x:Key="LOCGsPluginLinkingInProgress">正在关联...</sys:String>
    <sys:String x:Key="LOCGsPluginOpenWebsiteToLinkTooltip">在浏览器中打开 gamescrobbler.com 以自动关联账户</sys:String>
    <sys:String x:Key="LOCGsPluginTokenInputTooltip">在此输入您的关联令牌</sys:String>

    <!-- ── Install Token &amp; Diagnostics ── -->
    <sys:String x:Key="LOCGsPluginTokenStatusActive">&#x2713; 令牌：已激活</sys:String>
    <sys:String x:Key="LOCGsPluginTokenStatusPending">&#x26A0; 令牌：等待注册</sys:String>
    <sys:String x:Key="LOCGsPluginPendingScrobblesFormat">{0} 条记录排队中——将自动重试</sys:String>
    <sys:String x:Key="LOCGsPluginDroppedScrobblesFormat">{0} 条记录因服务器错误丢失</sys:String>

