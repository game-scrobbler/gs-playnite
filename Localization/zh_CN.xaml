    <sys:String x:Key="LOCGsPluginSyncUpToDate">库已是最新状态。</sys:String>
    <sys:String x:Key="LOCGsPluginSyncCooldownFormat">库最近已同步。请在 {0} 后重试。</sys:String>
    <sys:String x:Key="LOCGsPluginSyncCooldownGeneric">库最近已同步。请稍后重试。</sys:String>
    <sys:String x:Key="LOCGsPluginSyncFailed">库同步失败。请查看日志。</sys:String>
    <sys:String x:Key="LOCGsPluginSyncError">库同步时遇到错误。</sys:String>

    <!-- ── Menu Items ── -->
    <sys:String x:Key="LOCGsPluginMenuSyncLibrary">立即同步库</sys:String>
    <sys:String x:Key="LOCGsPluginMenuOpenSettings">打开设置</sys:String>

