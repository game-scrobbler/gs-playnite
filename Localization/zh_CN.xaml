    <sys:String x:Key="LOCGsPluginInvalidLinkingToken">收到无效的关联令牌。</sys:String>
    <sys:String x:Key="LOCGsPluginUnexpectedUriErrorFormat">处理 URI 请求时发生意外错误：{0}</sys:String>

