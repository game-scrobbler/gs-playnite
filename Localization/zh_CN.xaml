    <sys:String x:Key="LOCGsPluginSyncSettingsSectionTitle">同步设置</sys:String>
    <sys:String x:Key="LOCGsPluginSyncAchievementsLabel">同步成就数据（需要 SuccessStory 或 Playnite Achievements 插件）</sys:String>
    <sys:String x:Key="LOCGsPluginSyncAchievementsTooltip">在库同步时从 SuccessStory 或 Playnite Achievements 插件读取成就数据。如果两者都未安装则无效。</sys:String>
    <sys:String x:Key="LOCGsPluginAchievementProviderMissingWarning">未找到成就插件——将跳过成就同步。</sys:String>
    <sys:String x:Key="LOCGsPluginAchievementProviderInstallLink">安装成就插件</sys:String>
    <sys:String x:Key="LOCGsPluginLibrarySyncLabel">库同步：</sys:String>

    <!-- ── Section 5: Notifications ── -->
    <sys:String x:Key="LOCGsPluginNotificationsSectionTitle">通知</sys:String>
    <sys:String x:Key="LOCGsPluginShowUpdateNotificationsLabel">显示版本更新通知</sys:String>
    <sys:String x:Key="LOCGsPluginShowImportantNotificationsLabel">显示 GameScrobbler 的重要通知</sys:String>

    <!-- ── Section 6: Privacy Controls ── -->
    <sys:String x:Key="LOCGsPluginPrivacySectionTitle">隐私控制</sys:String>
    <sys:String x:Key="LOCGsPluginDisableSentryLabel">禁用错误报告 (Sentry)</sys:String>
    <sys:String x:Key="LOCGsPluginDisablePostHogLabel">禁用分析 (PostHog)</sys:String>
    <sys:String x:Key="LOCGsPluginDisableScrobblingLabel">禁用游戏活动追踪 (Scrobbling)</sys:String>
    <sys:String x:Key="LOCGsPluginScrobblingDisabledWarning">依赖会话数据的功能将不可用</sys:String>

    <!-- ── Section 7: Danger Zone ── -->
    <sys:String x:Key="LOCGsPluginDangerZoneSectionTitle">危险操作</sys:String>
    <sys:String x:Key="LOCGsPluginDangerZoneWarning">仅当您想要删除 GameScrobbler 服务器上的 Playnite 数据时才使用此选项。删除后，您需要重新同意才能继续使用该插件。</sys:String>
    <sys:String x:Key="LOCGsPluginDeleteMyDataButton">删除我的数据</sys:String>
    <sys:String x:Key="LOCGsPluginOptBackInButton">重新启用</sys:String>

